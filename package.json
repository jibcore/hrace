    "@vue/test-utils": "1.3.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^27.0.0",
    "playwright": "^1.58.2",
    "vite": "npm:rolldown-vite@7.1.14",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.1.14"
    }
  }
